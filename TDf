btn2.MouseButton1Click:Connect(function()
	local Players = game:GetService("Players")
	local UserInputService = game:GetService("UserInputService")
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local Workspace = game:GetService("Workspace")

	local localPlayer = Players.LocalPlayer
	local displayPlayers = ReplicatedStorage:WaitForChild("displayPlayers")

	local ESP_COLORS = {
		tails = Color3.fromRGB(255, 165, 0),
		knuckles = Color3.fromRGB(255, 0, 0),
		eggman = Color3.fromRGB(255, 255, 0),
		amy = Color3.fromRGB(255, 105, 180),
		cream = Color3.fromRGB(255, 218, 185),
		sally = Color3.fromRGB(210, 180, 140),
		shadow = Color3.fromRGB(0, 0, 0),
		rouge = Color3.fromRGB(255, 255, 255),
		blaze = Color3.fromRGB(237, 179, 255),
		silver = Color3.fromRGB(192, 192, 192),
		sonic = Color3.fromRGB(0, 0, 255),
		metalsonic = Color3.fromRGB(0, 0, 155),
		kolossos = Color3.fromRGB(139, 0, 0),
		sonicexe = Color3.fromRGB(139, 0, 0),
		metalknuckles = Color3.fromRGB(181, 0, 0),
		vector = Color3.fromRGB(32, 197, 0),
		furnace = Color3.fromRGB(139, 0, 0),
		nexus = Color3.fromRGB(139, 0, 0),
		doll = Color3.fromRGB(139, 0, 0),
		tetanus = Color3.fromRGB(139, 0, 0),
		lordx = Color3.fromRGB(139, 0, 0),
		tailsdoll = Color3.fromRGB(139, 0, 0),
		fleetway = Color3.fromRGB(255, 242, 0),
		espio = Color3.fromRGB(128, 0, 128),
		charmy = Color3.fromRGB(210, 180, 140),
	}

	local SHADOW_OUTLINE_COLOR = Color3.fromRGB(200, 200, 200)

	local espEnabled = true
	local highlights = {}

	local function setHighlightColors(highlight, characterName, baseColor)
		if characterName == "shadow" then
			highlight.FillColor = ESP_COLORS.shadow
			highlight.OutlineColor = SHADOW_OUTLINE_COLOR
		else
			highlight.FillColor = baseColor
			highlight.OutlineColor = baseColor
		end
	end

	local function disableAllHighlights()
		for _, highlight in pairs(highlights) do
			if highlight and highlight.Parent then
				highlight.Enabled = false
			end
		end
	end

	local function cleanupStaleHighlights()
		for modelName, highlight in pairs(highlights) do
			if not displayPlayers:FindFirstChild(modelName) then
				if highlight then
					highlight:Destroy()
				end
				highlights[modelName] = nil
			end
		end
	end

	local function applyHighlightToEntry(entry)
		local stats = entry:FindFirstChild("stats")
		if not stats then return end

		local characterValue = stats:FindFirstChild("character")
		if not characterValue then return end

		local characterName = tostring(characterValue.Value):lower()
		local baseColor = ESP_COLORS[characterName]
		if not baseColor then return end

		local model = Workspace:FindFirstChild(entry.Name)
		if not (model and model:IsA("Model")) then return end
		if model == localPlayer.Character then return end

		local existingHighlight = highlights[model.Name]

		if not existingHighlight then
			local highlight = Instance.new("Highlight")
			highlight.FillTransparency = 0.4
			highlight.OutlineTransparency = 0
			highlight.Adornee = model
			highlight.Enabled = espEnabled
			setHighlightColors(highlight, characterName, baseColor)
			highlight.Parent = Workspace
			
			highlights[model.Name] = highlight
		else
			setHighlightColors(existingHighlight, characterName, baseColor)
			existingHighlight.Enabled = espEnabled
		end
	end

	local function refreshESP()
		if not espEnabled then
			disableAllHighlights()
			return
		end

		cleanupStaleHighlights()

		for _, entry in ipairs(displayPlayers:GetChildren()) do
			applyHighlightToEntry(entry)
		end
	end

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.U then
			espEnabled = not espEnabled
			refreshESP()
		end
	end)

	displayPlayers.ChildAdded:Connect(refreshESP)
	displayPlayers.ChildRemoved:Connect(refreshESP)

	task.spawn(function()
		while task.wait(1) do
			refreshESP()
		end
	end)

	refreshESP()
end)

