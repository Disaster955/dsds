local RESET_SIZE = UDim2.new(1, 0, 1, 0)
local RESET_POS = UDim2.new(0, 0, 0, 0)

local BUTTON_GRADIENT = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
	ColorSequenceKeypoint.new(0.33, Color3.fromRGB(255, 255, 255)),
	ColorSequenceKeypoint.new(0.483, Color3.fromRGB(139, 139, 139)),
	ColorSequenceKeypoint.new(0.653, Color3.fromRGB(255, 255, 255)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
})

local function getHud()
	local playerGui = localPlayer:WaitForChild("PlayerGui")
	local gui = playerGui:WaitForChild("gui")
	return gui:WaitForChild("hud")
end

local function getMobile()
	local hud = getHud()
	local abilities = hud:WaitForChild("abilities")
	local abilitiesScreen = abilities:WaitForChild("abilitiesScreen")
	return abilitiesScreen:WaitForChild("mobile")
end

local function styleGlow(container)
	local glow = container:FindFirstChild("glow", true) or container:FindFirstChild("Glow", true)
	if glow and glow:IsA("ImageLabel") then
		glow.Image = "rbxassetid://5538771868"
		glow.ImageColor3 = CONFIG.glowColor
		glow.ImageTransparency = 0
		glow.BackgroundTransparency = 1
	end
end

local function applyStroke(label)
	local stroke = label:FindFirstChildOfClass("UIStroke")
	if not stroke then
		stroke = Instance.new("UIStroke")
		stroke.Parent = label
	end
	stroke.Color = CONFIG.strokeColor
	stroke.Thickness = CONFIG.strokeThickness
	stroke.Transparency = CONFIG.strokeTransparency
	stroke.ZIndex = CONFIG.strokeZIndex

	local gradient = stroke:FindFirstChildOfClass("UIGradient")
	if not gradient then
		gradient = Instance.new("UIGradient")
		gradient.Parent = stroke
	end
	gradient.Rotation = 90
end

local function styleButtonGradient(buttonObj)
	if not buttonObj or not buttonObj:IsA("GuiObject") then return end
	local grad = buttonObj:FindFirstChildOfClass("UIGradient")
	if grad then
		grad.Color = BUTTON_GRADIENT
	end
end

local function lockButton(btn)
	if not (btn and btn:IsA("ImageButton")) then return end
	if btn:GetAttribute("BtnLocked") then return end
	btn:SetAttribute("BtnLocked", true)

	local applying = false
	local function enforce()
		if applying then return end
		if btn.Size == RESET_SIZE and btn.Position == RESET_POS then
			applying = true
			btn.Size = BTN_SIZE
			btn.Position = BTN_POS
			applying = false
		end
	end

	enforce()
	btn:GetPropertyChangedSignal("Size"):Connect(enforce)
	btn:GetPropertyChangedSignal("Position"):Connect(enforce)
end

local function styleButton(container)
	local btn = container:FindFirstChild("button", true)
	if not btn or not btn:IsA("GuiObject") then return end
	styleButtonGradient(btn)
	if btn:IsA("ImageButton") then
		lockButton(btn)
	end
end

local function styleText(container)
	local abilityName = container:FindFirstChild("abilityName", true)
	if abilityName and abilityName:IsA("TextLabel") then
		abilityName.TextColor3 = CONFIG.textColor
		abilityName.AnchorPoint = Vector2.new(0.5, abilityName.AnchorPoint.Y)
		abilityName.Position = UDim2.new(0.5, 0, abilityName.Position.Y.Scale, abilityName.Position.Y.Offset)
		abilityName.TextXAlignment = Enum.TextXAlignment.Center
		applyStroke(abilityName)
	end

	local btn = container:FindFirstChild("button", true)
	if btn and btn:IsA("GuiObject") then
		local message = btn:FindFirstChild("message")
		if message and message:IsA("TextLabel") then
			message.TextColor3 = CONFIG.textColor
			applyStroke(message)
		end
	end
end

local function styleRing(container)
	local ring = container:FindFirstChild("ring", true)
	if not ring or not ring:IsA("ImageLabel") then return end

	ring.ImageColor3 = CONFIG.ringColor

	local gradient = ring:FindFirstChildOfClass("UIGradient")
	if not gradient then
		gradient = Instance.new("UIGradient")
		gradient.Parent = ring
	end
	gradient.Rotation = 90
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
		ColorSequenceKeypoint.new(0.359, Color3.fromRGB(248, 248, 248)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(66, 66, 66)),
	})
end

local function applyAll(container)
	styleGlow(container)
	styleButton(container)
	styleText(container)
	styleRing(container)
end

local function observe(container)
	if not container or not container:IsA("GuiObject") then return end
	if container:GetAttribute("Observed") then return end
	container:SetAttribute("Observed", true)

	applyAll(container)

	container.DescendantAdded:Connect(function(desc)
		if desc:IsA("ImageLabel") then
			local n = desc.Name
			if n == "ring" then
				styleRing(container)
			elseif n == "glow" or n == "Glow" then
				styleGlow(container)
			end
		elseif desc:IsA("TextLabel") then
			local n = desc.Name
			if n == "abilityName" or n == "message" then
				styleText(container)
			end
		elseif desc:IsA("UIGradient") then
			local p = desc.Parent
			if p and p:IsA("GuiObject") and p.Name == "button" then
				styleButtonGradient(p)
			end
		elseif desc:IsA("ImageButton") and desc.Name == "button" then
			styleButtonGradient(desc)
			lockButton(desc)
			styleText(container)
		elseif desc:IsA("GuiObject") and desc.Name == "button" then
			styleButtonGradient(desc)
			styleText(container)
		end
	end)
end

local function observeChildren(parent)
	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("GuiObject") then
			observe(child)
		end
	end
	parent.ChildAdded:Connect(function(child)
		if child:IsA("GuiObject") then
			observe(child)
		end
	end)
end

local function observeHudExtras(hud)
	for _, name in ipairs({ "pingButton", "revive", "run" }) do
		observe(hud:WaitForChild(name))
	end
end

local function run()
	local mobile = getMobile()
	observeChildren(mobile)

	local hud = getHud()
	observeHudExtras(hud)

	mobile.AncestryChanged:Connect(function(_, parent)
		if not parent then
			task.defer(run)
		end
	end)
end

run()
