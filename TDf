	end

	local savedVolumes = setmetatable({}, { __mode = "k" })

	local function setMuted(sound, shouldMute)
		if not sound or not sound:IsA("Sound") or sound == currentSound then return end
		if shouldMute then
			if savedVolumes[sound] == nil then
				savedVolumes[sound] = sound.Volume
			end
			sound.Volume = 0
		else
			local prev = savedVolumes[sound]
			if prev ~= nil then
				sound.Volume = prev
