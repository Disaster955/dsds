			end
		end)
	
		character.AncestryChanged:Connect(function(_, parent)
			if not parent then
				conn:Disconnect()
			end
		end)
	end
	
	if player.Character then
		watchCharacter(player.Character)
	end
	player.CharacterAdded:Connect(watchCharacter)
	
	-- ==================== PRIORITY ICON GUI ====================
	local ROOT_GUI_NAME = "gui"
	
	local Allowed = {
		["cream"] = true,
		["sally"] = true,
		["rouge"] = true,
		["metal knuckles"] = true,
		["metalknuckles"] = true,
		["vector"] = true,
	}
	
	local StrokeColor = Color3.fromRGB(170, 62, 0)
	local StrokeThickness = 2
	local StrokeTransparency = 0
	
	local GradientRotation = -90
	local GradientColors = ColorSequence.new({
		ColorSequenceKeypoint.new(0,     Color3.fromRGB(171, 61, 0)),
		ColorSequenceKeypoint.new(0.604, Color3.fromRGB(181, 181, 181)),
		ColorSequenceKeypoint.new(1,     Color3.fromRGB(255, 255, 255)),
	})
	
	local IconName = "PriorityIcon"
	local IconAsset = "rbxassetid://5538771868"
	
	local MobilePos = UDim2.new(-0.2, 0, -0.5, 0)
	local MobileSize = UDim2.new(0.2, 0, 1, 0)
	
	local enabled = false
	local listConn
	local guiConn
	local charAddedConn
	local charValueConn
	
	local function norm(v)
		local s = tostring(v or ""):lower()
		return (s:gsub("^%s+", ""):gsub("%s+$", ""):gsub("%s+", " "))
	end
	
	local function getList()
		local root = PlayerGui:FindFirstChild(ROOT_GUI_NAME)
		if not root then return end
		local hud = root:FindFirstChild("hud")
		if not hud then return end
		local healthbars = hud:FindFirstChild("healthbars")
		if not healthbars then return end
		return healthbars:FindFirstChild("list")
	end
	
	local function ensureIcon(parent)
		local img = parent:FindFirstChild(IconName)
		if not img then
			img = Instance.new("ImageLabel")
			img.Name = IconName
			img.Parent = parent
		end
		img.AnchorPoint = Vector2.new(0.5, 0.5)
		img.BackgroundTransparency = 1
		img.Position = UDim2.new(0.5, 0, 0.5, 0)
		img.Rotation = 0
		img.Size = UDim2.new(1.5, 0, 1.5, 0)
		img.ZIndex = 1
		img.Image = IconAsset
		img.ImageColor3 = Color3.fromRGB(0, 255, 0)
		img.ImageTransparency = 0.5
		return img
	end
	
	local function lockVisible(obj, value)
		obj.Visible = value
		if not obj:GetAttribute("_LckVis") then
			obj:SetAttribute("_LckVis", true)
			obj:GetPropertyChangedSignal("Visible"):Connect(function()
				if enabled and obj.Parent then
					obj.Visible = value
				end
			end)
		end
	end
	
	local function lockArrowTransparency(arrow)
		arrow.BackgroundTransparency = 1
		if arrow:IsA("ImageLabel") or arrow:IsA("ImageButton") then
			arrow.ImageTransparency = 1
		elseif arrow:IsA("TextLabel") or arrow:IsA("TextButton") or arrow:IsA("TextBox") then
			arrow.TextTransparency = 1
			arrow.TextStrokeTransparency = 1
		end
	
		if arrow:GetAttribute("_LckTr") then return end
		arrow:SetAttribute("_LckTr", true)
	
		arrow:GetPropertyChangedSignal("BackgroundTransparency"):Connect(function()
			if enabled and arrow.Parent then arrow.BackgroundTransparency = 1 end
		end)
	
		if arrow:IsA("ImageLabel") or arrow:IsA("ImageButton") then
			arrow:GetPropertyChangedSignal("ImageTransparency"):Connect(function()
				if enabled and arrow.Parent then arrow.ImageTransparency = 1 end
			end)
		elseif arrow:IsA("TextLabel") or arrow:IsA("TextButton") or arrow:IsA("TextBox") then
			arrow:GetPropertyChangedSignal("TextTransparency"):Connect(function()
				if enabled and arrow.Parent then arrow.TextTransparency = 1 end
			end)
			arrow:GetPropertyChangedSignal("TextStrokeTransparency"):Connect(function()
				if enabled and arrow.Parent then arrow.TextStrokeTransparency = 1 end
			end)
		end
	end
	
	local function applyEntry(entry)
		if not enabled then return end
		local healthbar = entry:FindFirstChild("healthbar")
		if not healthbar then return end
	
		local keybind = healthbar:FindFirstChild("teammatePriorityKeybind")
		local icon
	
		if keybind and keybind:IsA("GuiObject") then
			lockVisible(keybind, true)
	
			local stroke = keybind:FindFirstChildWhichIsA("UIStroke", true)
			if stroke then
				stroke.Color = StrokeColor
				stroke.Thickness = StrokeThickness
				stroke.Transparency = StrokeTransparency
			end
	
			local grad = keybind:FindFirstChildWhichIsA("UIGradient", true)
			if grad then
				grad.Color = GradientColors
				grad.Rotation = GradientRotation
			end
	
			icon = ensureIcon(keybind)
		end
	
		local mobile = healthbar:FindFirstChild("mobileButton")
		if mobile and mobile:IsA("GuiObject") then
			mobile.Position = MobilePos
			mobile.Size = MobileSize
		end
	
		local arrow = healthbar:FindFirstChild("teammatePriorityArrow")
		if arrow and arrow:IsA("GuiObject") then
			lockArrowTransparency(arrow)
			if icon and icon:IsA("GuiObject") then
				icon.Visible = arrow.Visible
				if not arrow:GetAttribute("_SyncVis") then
					arrow:SetAttribute("_SyncVis", true)
					arrow:GetPropertyChangedSignal("Visible"):Connect(function()
						if enabled and icon and icon.Parent then
							icon.Visible = arrow.Visible
						end
					end)
				end
			end
		end
	end
	
	local function applyAllPriority()
		if not enabled then return end
		local list = getList()
		if not list then return end
		for _, child in ipairs(list:GetChildren()) do
			applyEntry(child)
		end
	end
	
	local function hookList()
		local list = getList()
		if not list or listConn then return end
		listConn = list.ChildAdded:Connect(function(child)
			task.defer(applyEntry, child)
		end)
	end
	
	local function unhookList()
		if listConn then
			listConn:Disconnect()
			listConn = nil
		end
	end
	
	local function setEnabled(v)
		if v == enabled then return end
		enabled = v
		if enabled then
			hookList()
			applyAllPriority()
		else
			unhookList()
		end
	end
	
	local function watchCharacterValue()
		local displayPlayers = ReplicatedStorage:WaitForChild("displayPlayers")
		local pf = displayPlayers:WaitForChild(player.Name)
		local stats = pf:WaitForChild("stats")
		local charVal = stats:WaitForChild("character")
	
		local function refresh()
			setEnabled(Allowed[norm(charVal.Value)] == true)
		end
	
		refresh()
		if charValueConn then charValueConn:Disconnect() end
		charValueConn = charVal:GetPropertyChangedSignal("Value"):Connect(refresh)
	end
	
	guiConn = PlayerGui.ChildAdded:Connect(function(child)
		if child.Name == ROOT_GUI_NAME and enabled then
			task.defer(function()
				hookList()
				applyAllPriority()
			end)
		end
	end)
	
	charAddedConn = player.CharacterAdded:Connect(function()
		if enabled then
			task.delay(0.2, function()
				hookList()
				applyAllPriority()
			end)
		end
	end)
	
	watchCharacterValue()
	hookList()
	applyAllPriority()
	
	-- ==================== SECONDARY HUD (GLIDE / SILVER) ====================
	local function setTransparency(obj, value)
		if obj:IsA("GuiObject") then
			obj.BackgroundTransparency = value
		end
		if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
			obj.ImageTransparency = value
		end
	end
	
	local function setTextTransparency(obj, value)
		if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
			obj.TextTransparency = value
		end
	end
	
	local function enforceVisibilityPair(secondaryHud)
		local bind = secondaryHud:FindFirstChild("glideCarryBind")
		local cancel = secondaryHud:FindFirstChild("glideCarryCancel")
		if not (bind and cancel and bind:IsA("GuiObject") and cancel:IsA("GuiObject")) then return end
	
		local busy = false
		local function sync()
			if busy then return end
			busy = true
			if cancel.Visible then
				bind.Visible = true
			end
			busy = false
		end
	
		sync()
		bind:GetPropertyChangedSignal("Visible"):Connect(sync)
		cancel:GetPropertyChangedSignal("Visible"):Connect(sync)
	end
	
	local function applyToGlideCarryBind(secondaryHud)
		local glideCarryBind = secondaryHud:FindFirstChild("glideCarryBind")
		if not glideCarryBind then return end
	
		glideCarryBind.Position = UDim2.new(0.59, 0, 0.4, 0)
		glideCarryBind.Size = UDim2.new(0.2, 0, 0.2, 0)
	
		local mobileButton = glideCarryBind:FindFirstChild("mobileButton")
		if mobileButton and mobileButton:IsA("GuiObject") then
			mobileButton.Position = UDim2.new(0.251, 0, 0, 0)
			mobileButton.Size = UDim2.new(0.5, 0, 1, 0)
		end
	
		local bind = glideCarryBind:FindFirstChild("bind")
		if bind and bind:IsA("ImageLabel") then
			bind.Visible = false
		end
	
		local stains = glideCarryBind:FindFirstChild("stains")
		if stains and stains:IsA("Frame") then
			local stainA = stains:FindFirstChild("stainA")
			local stainB = stains:FindFirstChild("stainB")
	
			local cA = Color3.fromRGB(80, 80, 80)
			local cB = Color3.fromRGB(90, 90, 90)
	
			if stainA then
				if stainA:IsA("Frame") then
					stainA.BackgroundColor3 = cA
				elseif stainA:IsA("ImageLabel") or stainA:IsA("ImageButton") then
					stainA.ImageColor3 = cA
				end
			end
			if stainB then
				if stainB:IsA("Frame") then
					stainB.BackgroundColor3 = cB
				elseif stainB:IsA("ImageLabel") or stainB:IsA("ImageButton") then
					stainB.ImageColor3 = cB
				end
			end
		end
	end
	
	local function applyToGlideCarryCancel(secondaryHud)
		local glideCarryCancel = secondaryHud:FindFirstChild("glideCarryCancel")
		if not glideCarryCancel then return end
	
		setTransparency(glideCarryCancel, 1)
		setTextTransparency(glideCarryCancel, 1)
	
		local mobileButton = glideCarryCancel:FindFirstChild("mobileButton")
		if mobileButton and mobileButton:IsA("GuiObject") then
			mobileButton.Size = UDim2.new(0.47, 0, 5.65, 0)
			mobileButton.Position = UDim2.new(2.5, 0, -4.45, 0)
		end
	
		local stroke = glideCarryCancel:FindFirstChild("stroke")
		if stroke and stroke:IsA("UIStroke") then
			stroke.Transparency = 1
		end
	
		local bind = glideCarryCancel:FindFirstChild("bind")
		if bind and bind:IsA("ImageLabel") then
			bind.Visible = false
		end
	
		local stains = glideCarryCancel:FindFirstChild("stains")
		if stains and stains:IsA("Frame") then
			stains.Visible = false
		end
	end
	
	local function applyToSilverBarrierBar(secondaryHud)
		local silverBarrierBar = secondaryHud:FindFirstChild("silverBarrierBar")
		if not silverBarrierBar then return end
	
		local barrierHealthText = silverBarrierBar:FindFirstChild("barrierHealthText")
		if barrierHealthText and barrierHealthText:IsA("TextLabel") then
			barrierHealthText.Size = UDim2.new(1, 0, 0.4, 0)
			barrierHealthText.Position = UDim2.new(0, 0, 1.17, 0)
	
			local gradient = barrierHealthText:FindFirstChildWhichIsA("UIGradient")
			if gradient then
				gradient.Rotation = 90
				gradient.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 255)),
					ColorSequenceKeypoint.new(0.6555, Color3.fromRGB(0, 130, 130)),
					ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
				})
			end
	
			local stroke = barrierHealthText:FindFirstChild("stroke")
			if stroke and stroke:IsA("UIStroke") then
				stroke.Thickness = 1.5
				stroke.Color = Color3.fromRGB(0, 82, 85)
			end
		end
	
		local bar = silverBarrierBar:FindFirstChild("bar")
		if bar and bar:IsA("Frame") then
			bar.BorderColor3 = Color3.fromRGB(38, 114, 114)
		end
	
		silverBarrierBar.Size = UDim2.new(0.168, 0, 0.058, 0)
		silverBarrierBar.Position = UDim2.new(0.423, 0, 0.72, 0)
	end
	
	local function applyAllSecondary(secondaryHud)
		applyToGlideCarryBind(secondaryHud)
		applyToGlideCarryCancel(secondaryHud)
		applyToSilverBarrierBar(secondaryHud)
		enforceVisibilityPair(secondaryHud)
	end
	
	local function watchSecondaryHud(secondaryHud)
		applyAllSecondary(secondaryHud)
		secondaryHud.DescendantAdded:Connect(function() applyAllSecondary(secondaryHud) end)
		secondaryHud.ChildAdded:Connect(function() applyAllSecondary(secondaryHud) end)
	end
	
	local function hookSecondaryGui()
		local gui = PlayerGui:WaitForChild("gui")
		local hud = gui:WaitForChild("hud")
	
		local function attach()
			local secondaryHud = hud:FindFirstChild("secondaryHud")
			if secondaryHud then
				watchSecondaryHud(secondaryHud)
			end
		end
	
		attach()
		hud.ChildAdded:Connect(function(child)
			if child.Name == "secondaryHud" then
				watchSecondaryHud(child)
			end
		end)
	end
	
	hookSecondaryGui()
	
	PlayerGui.ChildAdded:Connect(function(child)
		if child.Name == "gui" then
			hookSecondaryGui()
		end
	end)
end)