		["rbxassetid://125264422451398"] = "https://raw.githubusercontent.com/Disaster955/TD-E/main/HASE.mp3"
	}

	local FORCED_PITCH = {
		["rbxassetid://128251131354822"] = 1,
		["rbxassetid://109637297157745"] = 1
	}

	local PRELOADED_ASSETS = {}
	local CUSTOM_ASSET_SET = {}

	for originalId, url in pairs(MUSIC_MAP) do
		local normId = normalizeId(originalId)
		local filename = buildFileName(normId)
		local asset = downloadToFile(url, filename)
		if asset then
			PRELOADED_ASSETS[normId] = asset
			CUSTOM_ASSET_SET[asset] = true
			safeCall(ContentProvider.PreloadAsync, ContentProvider, {asset})
		end
	end

	local sound = SoundService:WaitForChild("mainSounds"):WaitForChild("current")

	local busy = false
	local currentCustomAsset = nil
	local lastValidTime = {}
	local previousTime = 0

	local function checkAndReplace()
		if busy then return end
		busy = true

		local currentSoundId = sound.SoundId
		local normalizedId = normalizeId(currentSoundId)

		local customAsset = PRELOADED_ASSETS[normalizedId]
		if not customAsset and CUSTOM_ASSET_SET[currentSoundId] then
			customAsset = currentSoundId
		end

		if customAsset then
			local wasPlaying = sound.Playing

			if currentCustomAsset ~= customAsset then
				lastValidTime[customAsset] = 0
				currentCustomAsset = customAsset
			end

			if sound.SoundId ~= customAsset then
				sound:Stop()
				sound.SoundId = customAsset

				task.delay(0.04, function()
					if sound.SoundId == customAsset then
						sound.Looped = true
						local forced = FORCED_PITCH[normalizedId]
						if forced then sound.Pitch = forced end
						local saved = lastValidTime[customAsset]
						if saved and saved > 0.5 then
							sound.TimePosition = saved
						end
						if wasPlaying then sound:Play() end
					end
				end)
			end
		else
			if currentCustomAsset then
				currentCustomAsset = nil
				previousTime = 0
			end

			sound.TimePosition = 0
			if not sound.Playing then sound:Play() end

			task.spawn(function()
				for _ = 1, 3 do
					task.wait()
					if sound.SoundId == currentSoundId and currentSoundId ~= "" and not currentCustomAsset then
						sound.TimePosition = 0
					end
				end
			end)
		end

		busy = false
	end

	sound:GetPropertyChangedSignal("SoundId"):Connect(checkAndReplace)
	checkAndReplace()

	RunService.Heartbeat:Connect(function()
		if busy or not currentCustomAsset or sound.SoundId ~= currentCustomAsset or not sound.Playing then return end

		local curr = sound.TimePosition
		local len = sound.TimeLength or 9999

		if curr < 0.15 and previousTime > (len * 0.9) then
			lastValidTime[currentCustomAsset] = 0
		elseif curr < 0.15 and lastValidTime[currentCustomAsset] and lastValidTime[currentCustomAsset] > 6 then
			sound.TimePosition = lastValidTime[currentCustomAsset]
		else
			lastValidTime[currentCustomAsset] = curr
		end

		previousTime = curr
	end)
end)

