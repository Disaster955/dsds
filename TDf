	local function safeCall(fn, ...)
		local success, result = pcall(fn, ...)
		return success, result
	end

	local function normalizeId(id)
		id = tostring(id or "")
		if id:find("^rbxassetid://") then return id end
		local digits = id:match("%d+")
		return digits and "rbxassetid://" .. digits or id
	end

	local function buildFileName(soundId)
		local digits = tostring(soundId):gsub("rbxassetid://", ""):gsub("%D", "")
		return "dynamic_" .. digits .. ".mp3"
	end

	local function downloadToFile(url, filename)
		local ok, data = safeCall(game.HttpGet, game, url, true)
		if ok and data then
			safeCall(writefile, filename, data)
		end
		if isfile(filename) then
			local okAsset, asset = safeCall(getcustomasset, filename)
			if okAsset and asset then return asset end
		end
		return nil
	end

	local MUSIC_MAP = {
		["rbxassetid://129419473647568"] = "https://raw.githubusercontent.com/Disaster955/TD-E/main/Hill.mp3",
		["rbxassetid://97481294713917"] = "https://raw.githubusercontent.com/Disaster955/TD-E/main/YCR.mp3",
		["rbxassetid://120557912060208"] = "https://raw.githubusercontent.com/Disaster955/TD-E/main/YCRE.mp3",
		["rbxassetid://121941894006487"] = "https://raw.githubusercontent.com/Disaster955/TD-E/main/HillGym.mp3",
		["rbxassetid://128251131354822"] = "https://raw.githubusercontent.com/Disaster955/TD-E/main/NP.mp3",
